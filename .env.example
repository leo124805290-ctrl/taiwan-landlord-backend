# 應用配置
NODE_ENV=development
PORT=3001
API_PREFIX=/api

# 資料庫配置
DATABASE_URL=postgresql://username:password@localhost:5432/taiwan_landlord_db

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:3000,https://taiwan-landlord-vietnam-tenant-syst.vercel.app

# 安全配置
RATE_LIMIT_WINDOW_MS=900000  # 15分鐘
RATE_LIMIT_MAX_REQUESTS=100  # 每個IP每15分鐘100次請求

# 日誌配置
LOG_LEVEL=info

# 管理員初始帳號（首次啟動時創建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!
ADMIN_EMAIL=admin@example.com